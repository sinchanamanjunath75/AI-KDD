# DRIFT.AI Backend Environment Variables

# Supabase PostgreSQL Connection String (Optional - defaults to local SQLite if empty)
DATABASE_URL=postgresql://postgres.xxx:YOUR-PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Google Gemini API Key (Required for AI drift detection)
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
